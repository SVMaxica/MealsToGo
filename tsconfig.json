{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "allowJs": true,
    "skipLibCheck": true,

    "strict": true,
    "baseUrl": "./",
    "jsx": "react-native",
    "typeRoots": ["./node_modules/@types"],
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src/**/*", ".expo/types/**/*.ts", "expo-env.d.ts"],
  "exclude": ["node_modules", "assets", "app"]
}
